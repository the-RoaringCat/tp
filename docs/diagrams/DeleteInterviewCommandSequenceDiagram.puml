@startuml
actor User
participant ":Parser" as Parser
participant ":Executor" as Exec
participant ":DeleteInterviewCommand" as Cmd
participant ":InternshipList" as List
participant ":InterviewList" as IVL
participant ":Internship" as Intern

User -> Parser : "delete-interview 1"
activate Parser
Parser --> Exec : parsed command
deactivate Parser

Exec -> Exec : get command "delete-interview"
Exec -> Cmd : execute()
activate Cmd

Cmd -> Cmd : getParamsOf("delete-interview")
note right of Cmd : retrieves ["1"]

alt no index or invalid
    Cmd -> User : "Please provide the index..."
else index valid
    Cmd -> List : getSize()
    activate List
    List --> Cmd : size
    deactivate List

    alt index out of range
        Cmd -> User : "Invalid index!"
    else index valid
        Cmd -> List : get(index - 1)
        activate List
        List --> Cmd : Internship
        deactivate List

        Cmd -> IVL : getInterviews()
        activate IVL
        IVL --> Cmd : interviews
        deactivate IVL

        Cmd -> Cmd : search for interview by company name

        alt interview not found
            Cmd -> User : "This internship does not have an interview scheduled."
        else interview found
            Cmd -> IVL : remove(interview)
            activate IVL
            IVL --> Cmd
            deactivate IVL

            Cmd -> Intern : deleteInterview()
            activate Intern
            Intern --> Cmd
            deactivate Intern

            Cmd -> Cmd : ui.print("✓ Deleted interview for ...")
        end
    end
end

deactivate Cmd
@enduml
