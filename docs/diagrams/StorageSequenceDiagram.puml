@startuml
actor User
participant ":GoldenCompass" as GC
participant ":InternshipStorage" as InternStorage
participant ":InterviewStorage" as InterviewStorage
participant ":AliasStorage" as AliasStorage

User -> GC : "bye"
activate GC

note right of GC : GoldenCompass triggers\nsave for all data types

GC -> InternStorage : save(internshipList)
activate InternStorage
InternStorage -> InternStorage : Write formatting logic
InternStorage --> GC
deactivate InternStorage

GC -> InterviewStorage : save(interviewList)
activate InterviewStorage
InterviewStorage -> InterviewStorage : Write formatting logic
InterviewStorage --> GC
deactivate InterviewStorage

GC -> AliasStorage : save(aliasMap)
activate AliasStorage
AliasStorage -> AliasStorage : Write formatting logic
AliasStorage --> GC
deactivate AliasStorage

GC --> User : "Goodbye!"
deactivate GC
@enduml