@startuml
actor User
participant ":Ui" as Ui
participant ":GoldenCompass" as GC
participant ":Parser" as Parser
participant ":Executor" as Executor
participant ":SetInterviewDeadlineCommand" as SDC
participant ":InterviewList" as IVL
participant "iv:Interview" as IV

User -> Ui : "update-date 1 /d 2025-04-15 14:00"
activate Ui
Ui --> GC : returns input
deactivate Ui

GC -> Parser : parse("update-date 1 /d 2025-04-15 14:00")
activate Parser
Parser --> GC
deactivate Parser

GC -> Executor : execute()
activate Executor
Executor -> SDC : execute()
activate SDC

SDC -> SDC : getParamsOf(parser.getCommand())
note right of SDC : retrieves ["1"]

SDC -> SDC : getParamsOf("/d")
note right of SDC : retrieves ["2025-04-15 14:00"]

alt missing index or date
    SDC -> Ui : error message
else params present
    SDC -> SDC : parseInt("1")
    SDC -> IVL : isValidIndex(1)
    activate IVL
    IVL --> SDC : true
    deactivate IVL

    alt index out of range
        SDC -> Ui : "Index is out of range."
    else index valid
        SDC -> SDC : validate shape (regex) and strict-parse to LocalDateTime

        alt invalid format or calendar date
            SDC -> Ui : "Invalid date format..." or "... is not a valid date."
        else date parses
            alt date is in the past
                SDC -> Ui : "Interview date ... is in the past."
            else date valid
                SDC -> IVL : get(index - 1)
                activate IVL
                IVL --> SDC : iv
                deactivate IVL

                SDC -> IV : setDate(2025-04-15T14:00)
                activate IV
                IV --> SDC
                deactivate IV

                SDC -> IVL : getInterviews().sort(by date)
                activate IVL
                IVL --> SDC
                deactivate IVL

                SDC -> Ui : print("Deadline set for interview 1: ...")
                activate Ui
                Ui --> SDC
                deactivate Ui
            end
        end
    end
end

deactivate SDC
deactivate Executor
@enduml
