@startuml
actor User
participant ":Ui" as Ui
participant ":GoldenCompass" as GC
participant ":Parser" as Parser
participant ":Executor" as Executor
participant ":SetInterviewDeadlineCommand" as SDC
participant ":InterviewList" as IVL
participant "iv:Interview" as IV

User -> Ui : "set-deadline 1 /d 2025-04-15"
activate Ui
Ui --> GC : returns input
deactivate Ui

GC -> Parser : parse("set-deadline 1 /d 2025-04-15")
activate Parser
Parser --> GC
deactivate Parser

GC -> Executor : execute()
activate Executor
Executor -> SDC : execute()
activate SDC

SDC -> Parser : getParamsOf("set-deadline")
activate Parser
Parser --> SDC : ["1"]
deactivate Parser

SDC -> Parser : getParamsOf("/d")
activate Parser
Parser --> SDC : ["2025-04-15"]
deactivate Parser

SDC -> IVL : isValidIndex(1)
activate IVL
IVL --> SDC : true
deactivate IVL

note right of SDC : Parses "2025-04-15" into LocalDate

SDC -> IVL : get(0)
activate IVL
IVL --> SDC : iv
deactivate IVL

SDC -> IV : setDate(2025-04-15)
activate IV
IV --> SDC
deactivate IV

SDC -> Ui : print("Deadline set for interview 1: 2025-04-15")
activate Ui
Ui --> SDC
deactivate Ui

deactivate SDC
deactivate Executor
@enduml
