@startuml
actor User
participant ":ListCommand" as ListCommand
participant ":InternshipList" as InternshipList
participant ":Internship" as Internship

User -> ListCommand : execute()
activate ListCommand

ListCommand -> InternshipList : getInternships()
activate InternshipList
InternshipList --> ListCommand : internships
deactivate InternshipList

alt internships == null or empty
    ListCommand -> ListCommand : ui.print("No internships in the list.")
    note right of ListCommand : Self-invocation
else internships not empty
    ListCommand -> ListCommand : ui.print("Here are the internships you have added:")
    note right of ListCommand : Self-invocation

    loop for each internship
        ListCommand -> InternshipList : get(i)
        activate InternshipList
        InternshipList --> ListCommand : internship
        deactivate InternshipList

        ListCommand -> Internship : toString()
        activate Internship
        Internship --> ListCommand : formatted string
        deactivate Internship

        ListCommand -> ListCommand : ui.print(index + ". " + formattedString)
        note right of ListCommand : Self-invocation
    end
end

deactivate ListCommand
@enduml
