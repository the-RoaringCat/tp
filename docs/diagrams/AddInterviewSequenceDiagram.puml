@startuml
actor User
participant ":Parser" as Parser
participant ":Executor" as Executor
participant ":AddInterviewCommand" as AIC
participant ":InternshipList" as IL
participant ":Internship" as Intern
participant ":InterviewList" as IVL

User -> Parser : "add-interview 2 /d 2025-06-15 10:00"
activate Parser
Parser --> Executor : parsed command
deactivate Parser

Executor -> AIC : execute()
activate AIC

AIC -> AIC : getParamsOf(parser.getCommand())
note right of AIC : retrieves ["2"]

AIC -> AIC : getParamsOf("/d")
note right of AIC : retrieves ["2025-06-15 10:00"]

alt missing index or date
    AIC -> User : error message
else params present
    AIC -> AIC : parseInt("2")
    AIC -> IL : getSize()
    activate IL
    IL --> AIC : size
    deactivate IL

    alt index out of range
        AIC -> User : "Index is out of range."
    else index valid
        AIC -> AIC : parse date into LocalDateTime

        alt date is in the past
            AIC -> User : "Interview date ... is in the past."
        else date valid
            AIC -> IL : getInternships().get(index - 1)
            activate IL
            IL --> AIC : Internship
            deactivate IL

            AIC -> Intern : getInterview()
            activate Intern
            Intern --> AIC : interview or null
            deactivate Intern

            alt interview already exists
                AIC -> User : "... already has an interview scheduled."
            else no existing interview
                create "iv:Interview" as IV
                AIC -> IV : new Interview(internship, date)

                AIC -> Intern : setInterview(iv)
                activate Intern
                Intern --> AIC
                deactivate Intern

                AIC -> IVL : add(iv)
                activate IVL
                IVL --> AIC
                deactivate IVL

                AIC -> AIC : ui.print("Got it! I've added an interview...")
            end
        end
    end
end

deactivate AIC
@enduml
